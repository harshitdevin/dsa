#include <stdio.h>
#include <string.h>
#include <math.h>
#include <stdlib.h>

int main() {
    int len;
    scanf("%d",&len);
    int arr[len];
    for(int i=0;i<len;i++){
        scanf("%d",&arr[i]);
    }
    int num;
    scanf("%d",&num);
    int start =0;
    int end1=len-1;
    while(start<=end1){
        int mid=start+(end1-start)/2;
        if(num==arr[mid]){
            printf("%d ",num);
            printf("found in array");
            return mid;
        }
        else if(num<arr[mid]){
            end1=mid-1;
        }
        else{
            start=mid+1;
        }
    }
    printf("%d ",num);
    printf("not found in array");
    return 0;
}
